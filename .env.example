# Copy this file to .env and fill in the values.
# Get the Stream key from https://dashboard.getstream.io -> your app -> Overview
EXPO_PUBLIC_STREAM_API_KEY=qrp6sc4qxppt

# Base URL of the /server directory service.
# For on-device testing use your computer's LAN IP (NOT localhost / 127.0.0.1),
# with both phones on the same Wi-Fi, e.g. http://192.168.1.20:3000
EXPO_PUBLIC_API_URL=http://192.168.1.20:3000
